---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact">
  <!-- Page header -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-accent/5 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-6 pb-12 pt-24 md:pb-16 md:pt-32">
      <h1 class="mb-4 font-heading text-3xl text-white md:text-4xl lg:text-5xl">Contact</h1>
      <p class="max-w-2xl text-lg text-slate-300">
        Have a project in mind or just want to exchange ideas? I'm always open to
        conversations about software architecture, AI tooling, and what makes
        engineering teams effective.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-16 md:pb-24">
    <div class="grid gap-12 lg:grid-cols-5">
      <!-- Contact form -->
      <div class="lg:col-span-3">
        <form class="space-y-6" onsubmit="return false;">
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-slate-300">Name</label>
            <input
              id="name"
              type="text"
              class="w-full rounded-lg border border-slate-600 bg-slate-800/50 px-4 py-3 text-white placeholder-slate-500 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-slate-300">Email</label>
            <input
              id="email"
              type="email"
              class="w-full rounded-lg border border-slate-600 bg-slate-800/50 px-4 py-3 text-white placeholder-slate-500 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="subject" class="mb-2 block text-sm font-medium text-slate-300">Subject</label>
            <input
              id="subject"
              type="text"
              class="w-full rounded-lg border border-slate-600 bg-slate-800/50 px-4 py-3 text-white placeholder-slate-500 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="What's this about?"
            />
          </div>
          <div>
            <label for="message" class="mb-2 block text-sm font-medium text-slate-300">Message</label>
            <textarea
              id="message"
              rows="5"
              class="w-full rounded-lg border border-slate-600 bg-slate-800/50 px-4 py-3 text-white placeholder-slate-500 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              placeholder="Tell me about your project..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-slate-950 transition-colors hover:bg-accent-light focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-slate-900 sm:w-auto"
          >
            Send Message
          </button>
          <p class="text-xs text-slate-500">
            This form is a demo and does not send messages. For actual inquiries, please reach out via LinkedIn.
          </p>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-2">
        <div class="space-y-8">
          <!-- Availability -->
          <div class="rounded-xl border border-slate-700/50 bg-slate-900/40 p-6">
            <div class="mb-3 flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
              <span class="text-sm font-medium text-emerald-400">Available for new projects</span>
            </div>
            <p class="text-sm leading-relaxed text-slate-400">
              Currently accepting consulting engagements and project-based work.
              Typical response time is within 48 hours.
            </p>
          </div>

          <!-- Social links -->
          <div class="rounded-xl border border-slate-700/50 bg-slate-900/40 p-6">
            <h3 class="mb-4 font-heading text-lg text-white">Connect</h3>
            <div class="space-y-3">
              <a
                href="#"
                class="flex items-center gap-3 text-slate-300 transition-colors hover:text-accent"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span class="text-sm">LinkedIn</span>
              </a>
              <a
                href="#"
                class="flex items-center gap-3 text-slate-300 transition-colors hover:text-accent"
              >
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
                <span class="text-sm">GitHub</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
